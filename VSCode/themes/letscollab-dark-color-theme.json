  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a7e85"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#cf8e6d"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#6aab73"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#2aacb8"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#35a348"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#086984"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f75464"
      }
    },
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.documentation"
      ],
      "settings": {
        "foreground": "#5f826b"
      }
    },
    {
      "name": "Doc Tags",
      "scope": [
        "comment.block.documentation keyword",
        "comment.line.documentation keyword",
        "entity.name.tag.documentation",
        "storage.type.class.jsdoc"
      ],
      "settings": {
        "foreground": "#67a37c"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#bcbec4",
    "interface": "#bcbec4",
    "enum": "#b3ae60",
    "struct": "#bcbec4",
    "typeParameter": "#16baac",
    "function": "#56a8f5",
    "method": "#35a348",
    "property": "#086984",
    "parameter": "#bcbec4",
    "variable": "#bcbec4",
    "enumMember": "#086984",
    "namespace": "#bcbec4",
    "keyword": "#cf8e6d",
    "number": "#2aacb8",
    "string": "#6aab73",
    "operator": "#bcbec4",
    "comment": "#7a7e85",
    "macro": "#b3ae60"
  }
}
